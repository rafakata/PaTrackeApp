<!-- AÑADIR ESTO AL PRINCIPIO (después del layout) -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="row g-4">
  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="card-title">Estado del vehículo</h5>
        <div id="status-badge" class="badge bg-secondary fs-6 mb-3">Sin aparcamiento activo</div>

        <div id="info-panel" class="d-none">
          <p>📍 <strong>Distancia:</strong> <span id="distance">--</span></p>
          <p>⏱️ <strong>Tiempo:</strong> <span id="elapsed">--</span></p>
          <p class="text-muted small" id="coords-vehicle"></p>
        </div>

        <div class="d-grid gap-2 mt-3">
          <button id="btn-park" class="btn btn-success">🚗 He aparcado aquí</button>
          <button id="btn-end" class="btn btn-danger d-none">✅ Voy a coger el coche</button>
        </div>

        <% if (activeParking) { %>
          <div class="alert alert-info mt-3">
            Tienes un aparcamiento activo guardado en el servidor.
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-md-8">
    <div id="map" style="height: 450px; border-radius: 8px;"></div>
  </div>
</div>

<!-- CORREGIDO: JSON correcto + Leaflet + Bootstrap -->
<script>
  // Datos del servidor (aparcamiento activo si existe)
  const serverParking = <%- JSON.stringify(activeParking || null) %>;
</script>

<!-- AÑADIR Leaflet ANTES de map.js -->
<script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>
<script src="/javascripts/map.js"></script>
