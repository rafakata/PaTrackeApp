<h2 class="mb-4">📋 Historial de aparcamientos</h2>

<% if (history.length === 0) { %>
  <div class="alert alert-info">No tienes aparcamientos registrados.</div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th>#</th>
          <th>Latitud</th>
          <th>Longitud</th>
          <th>Fecha / Hora</th>
          <th>Estado</th>
        </tr>
      </thead>
      <tbody>
        <% history.forEach((p, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= p.lat.toFixed(5) %></td>
            <td><%= p.lng.toFixed(5) %></td>
            <td><%= new Date(p.timestamp).toLocaleString('es-ES') %></td>
            <td>
              <% if (p.active) { %>
                <span class="badge bg-success">Activo</span>
              <% } else { %>
                <span class="badge bg-secondary">Finalizado</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<a href="/" class="btn btn-primary mt-2">← Volver al mapa</a>
