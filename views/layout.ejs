<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>PaTrackeApp</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css"/>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Zen+Dots&family=Poppins:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/stylesheets/root.css">
</head>
<body class="d-flex flex-column min-vh-100">
  <nav class="navbar navbar-dark app-chrome px-3">
    <a class="navbar-brand" href="/">PaTrackeApp</a>
    <div class="d-flex gap-2">
      <% if (user) { %>
        <span class="navbar-text text-white me-2"><%= user.username %></span>
        <form action="/logout" method="POST" class="d-inline">
          <button class="btn btn-danger btn-sm">Salir</button>
        </form>
      <% } else { %>
        <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
      <% } %>
    </div>
  </nav>

  <main class="container py-4 flex-fill">
    <%- body %>
  </main>

  <footer class="app-chrome text-white text-center py-3 mt-auto w-100">
    PaTrackeApp &copy; Rafael Medina Quelle
  </footer>

  <script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
</body>
</html>
