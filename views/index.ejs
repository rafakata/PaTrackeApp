<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="row g-4">
  <div class="col-md-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="card-title">Estado del vehículo</h5>
        <div id="status-badge" class="badge bg-secondary fs-6 mb-3">Sin aparcamiento activo</div>

        <div id="info-panel" class="d-none">
          <p><i class="bi bi-geo-alt-fill me-1"></i><strong>Distancia:</strong> <span id="distance">--</span></p>
          <p><i class="bi bi-stopwatch-fill me-1"></i><strong>Tiempo:</strong> <span id="elapsed">--</span></p>
          <p class="text-muted small" id="coords-vehicle"></p>
        </div>

        <div class="d-grid gap-2 mt-3">
          <button id="btn-park" class="btn btn-success"><i class="bi bi-geo-alt-fill me-1"></i>He aparcado aquí</button>
          <button id="btn-end" class="btn btn-danger d-none"><i class="bi bi-car-front-fill me-1"></i>Voy a coger el coche</button>
        </div>

        <% if (activeParking) { %>
          <div class="alert alert-info mt-3">
            Tienes un aparcamiento activo guardado en el servidor.
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-md-8">
    <div id="map" style="height: 450px; border-radius: 8px;"></div>
  </div>
</div>

<div class="row mt-5 justify-content-center">
  <div class="col-md-12">
    <h2 class="mb-4">Historial de aparcamientos</h2>
    <div class="table-responsive" style="min-height: 450px;">
      <table id="history-table" class="table table-striped table-hover w-100">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Latitud</th>
            <th>Longitud</th>
            <th>Fecha / Hora</th>
            <th>Tiempo</th>
            <th>Estado</th>
          </tr>
        </thead>
        <tbody id="history-body"></tbody>
      </table>
    </div>
  </div>
</div>

<script>
  const serverParking = <%- JSON.stringify(activeParking || null) %>;
  const isLogged = <%= user ? 'true' : 'false' %>;
  const currentUserId = <%- JSON.stringify(user ? user.id : null) %>;
  const initialHistory = <%- JSON.stringify(history || []) %>;
</script>

<script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>
<script src="/javascripts/map.js"></script>
